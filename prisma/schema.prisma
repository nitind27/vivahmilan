generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─── NextAuth required tables ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core User ───────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String?   @unique
  emailVerified     DateTime?
  image             String?   @db.Text
  password          String?
  phone             String?   @unique
  phoneVerified     Boolean   @default(false)
  role              Role      @default(USER)
  isActive          Boolean   @default(true)
  isVerified        Boolean   @default(false)
  adminVerified     Boolean   @default(false)  // admin must approve
  verificationBadge Boolean   @default(false)
  isPremium         Boolean   @default(false)
  premiumExpiry     DateTime?
  premiumPlan       String?
  profileBoost      Boolean   @default(false)
  boostExpiry       DateTime?
  loginOtpEnabled   Boolean   @default(false)
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  profile      Profile?
  photos       Photo[]
  sentInterests     Interest[] @relation("SentInterests")
  receivedInterests Interest[] @relation("ReceivedInterests")
  sentMessages      Message[]  @relation("SentMessages")
  receivedMessages  Message[]  @relation("ReceivedMessages")
  chatRoomsA        ChatRoom[] @relation("ChatRoomUserA")
  chatRoomsB        ChatRoom[] @relation("ChatRoomUserB")
  shortlisted       Shortlist[] @relation("ShortlistOwner")
  shortlistedBy     Shortlist[] @relation("ShortlistTarget")
  viewedProfiles    ProfileView[] @relation("Viewer")
  profileViews      ProfileView[] @relation("Viewed")
  notifications     Notification[]
  subscriptions     Subscription[]
  documents         Document[]
  reportsMade       Report[]   @relation("ReportMaker")
  reportsReceived   Report[]   @relation("ReportTarget")
  blockedUsers      Block[]    @relation("Blocker")
  blockedBy         Block[]    @relation("Blocked")
  otps              OTP[]
}

enum Role {
  USER
  ADMIN
}

// ─── Profile ─────────────────────────────────────────────────────────────────

model Profile {
  id               String    @id @default(cuid())
  userId           String    @unique
  gender           Gender?
  dob              DateTime?
  height           Int?      // in cm
  weight           Int?      // in kg
  religion         String?
  caste            String?
  subCaste         String?
  sect             String?
  gotra            String?
  motherTongue     String?
  education        String?
  profession       String?
  income           String?
  country          String?
  state            String?
  city             String?
  aboutMe          String?   @db.Text
  maritalStatus    MaritalStatus @default(NEVER_MARRIED)
  smoking          Lifestyle @default(NO)
  drinking         Lifestyle @default(NO)
  diet             String?
  complexion       String?
  bodyType         String?
  // Family
  fatherOccupation String?
  motherOccupation String?
  siblings         Int?
  familyType       String?
  familyStatus     String?
  // Partner prefs
  partnerAgeMin    Int?
  partnerAgeMax    Int?
  partnerHeightMin Int?
  partnerHeightMax Int?
  partnerReligion  String?
  partnerEducation String?
  partnerLocation  String?
  // Horoscope
  horoscopeSign    String?
  nakshatra        String?
  manglik          String?   @default("No")
  kundliMatch      String?   @default("Not Required")
  amritdhari       String?
  // Privacy
  hidePhone        Boolean   @default(false)
  hidePhoto        Boolean   @default(false)
  profileComplete  Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  NEVER_MARRIED
  DIVORCED
  WIDOWED
  SEPARATED
}

enum Lifestyle {
  NO
  OCCASIONALLY
  YES
}

// ─── Photos ──────────────────────────────────────────────────────────────────

model Photo {
  id        String   @id @default(cuid())
  userId    String
  url       String   @db.Text
  publicId  String?
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Interest / Connection ───────────────────────────────────────────────────

model Interest {
  id         String         @id @default(cuid())
  senderId   String
  receiverId String
  status     InterestStatus @default(PENDING)
  message    String?        @db.Text
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  sender   User @relation("SentInterests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedInterests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

enum InterestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── Chat ────────────────────────────────────────────────────────────────────

model ChatRoom {
  id        String    @id @default(cuid())
  userAId   String
  userBId   String
  createdAt DateTime  @default(now())
  messages  Message[]

  userA User @relation("ChatRoomUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("ChatRoomUserB", fields: [userBId], references: [id], onDelete: Cascade)

  @@unique([userAId, userBId])
}

model Message {
  id         String      @id @default(cuid())
  chatRoomId String
  senderId   String
  receiverId String
  content    String      @db.Text
  type       MessageType @default(TEXT)
  fileUrl    String?     @db.LongText
  fileName   String?
  fileSize   Int?
  latitude   Float?
  longitude  Float?
  locationType String? // 'current' | 'live'
  locationExpiry DateTime? // for live location expiry
  isRead     Boolean     @default(false)
  createdAt  DateTime    @default(now())

  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  sender   User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
  LOCATION
}

// ─── Shortlist ───────────────────────────────────────────────────────────────

model Shortlist {
  id        String   @id @default(cuid())
  ownerId   String
  targetId  String
  createdAt DateTime @default(now())

  owner  User @relation("ShortlistOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  target User @relation("ShortlistTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([ownerId, targetId])
}

// ─── Profile Views ───────────────────────────────────────────────────────────

model ProfileView {
  id        String   @id @default(cuid())
  viewerId  String
  viewedId  String
  createdAt DateTime @default(now())

  viewer User @relation("Viewer", fields: [viewerId], references: [id], onDelete: Cascade)
  viewed User @relation("Viewed", fields: [viewedId], references: [id], onDelete: Cascade)

  @@unique([viewerId, viewedId])
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum NotificationType {
  INTEREST_RECEIVED
  INTEREST_ACCEPTED
  MESSAGE_RECEIVED
  PROFILE_VIEWED
  SUBSCRIPTION_EXPIRY
  VERIFICATION_APPROVED
  SYSTEM
}

// ─── Dynamic Profile Options (admin configurable) ────────────────────────────
model ProfileOption {
  id        String   @id @default(cuid())
  category  String   // 'religion' | 'caste_Hindu' | 'caste_Muslim' | 'gotra' | 'motherTongue' | 'education' | 'profession' | 'income' | 'diet' | 'bodyType' | 'complexion' | 'familyType' | 'familyStatus' | 'maritalStatus'
  value     String
  label     String
  group     String?  // sub-group like 'Brahmin - UP/Bihar'
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([category, value])
  @@index([category, isActive])
}

// ─── Subscription Plan Config (admin configurable) ───────────────────────────
model PlanConfig {
  id          String   @id @default(cuid())
  plan        String   @unique  // SILVER | GOLD | PLATINUM | FREE
  displayName String
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("INR")
  durationDays Int     @default(30)
  isActive    Boolean  @default(true)
  // Permissions as JSON string
  permissions String   @db.Text  // JSON: { canChat, interestLimit, canSeeContact, ... }
  description String?  @db.Text
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

// ─── Subscription ────────────────────────────────────────────────────────────

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  plan      SubscriptionPlan
  status    SubscriptionStatus @default(ACTIVE)
  amount    Decimal            @db.Decimal(10, 2)
  currency  String             @default("USD")
  paymentId String?
  startDate DateTime           @default(now())
  endDate   DateTime
  createdAt DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SubscriptionPlan {
  SILVER
  GOLD
  PLATINUM
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

// ─── Document Verification ───────────────────────────────────────────────────

model Document {
  id         String           @id @default(cuid())
  userId     String
  type       String
  url        String           @db.Text
  publicId   String?
  status     VerificationStatus @default(PENDING)
  adminNote  String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Report ──────────────────────────────────────────────────────────────────

model Report {
  id         String       @id @default(cuid())
  reporterId String
  targetId   String
  reason     String
  details    String?      @db.Text
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())

  reporter User @relation("ReportMaker", fields: [reporterId], references: [id], onDelete: Cascade)
  target   User @relation("ReportTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
}

// ─── Block ───────────────────────────────────────────────────────────────────

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
}

// ─── OTP ─────────────────────────────────────────────────────────────────────

model OTP {
  id        String   @id @default(cuid())
  userId    String
  code      String
  type      OTPType
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum OTPType {
  EMAIL_VERIFY
  PHONE_VERIFY
  PASSWORD_RESET
}
