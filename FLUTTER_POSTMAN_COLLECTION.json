{
  "info": {
    "name": "Vivah Dwar - Flutter API",
    "description": "Complete REST API collection for Vivah Dwar Flutter mobile app.\n\nBase URL: https://vivahdwar.com\n\nAuth Flow:\n1. Register → 2. Verify OTP → 3. Login → 4. Use token in all protected APIs\n\nAll protected APIs need: Authorization: Bearer {token}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://vivahdwar.com", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "1. Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/flutter/auth/register", "host": ["{{baseUrl}}"], "path": ["api","flutter","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"phone\": \"+919876543210\",\n  \"password\": \"test1234\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Register a new user. OTP will be sent to email.\n\nRequired: name, email, password\nOptional: phone\n\nResponse: { success, message, userId, email }"
          }
        },
        {
          "name": "2. Verify OTP (Email)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/flutter/auth/verify-otp", "host": ["{{baseUrl}}"], "path": ["api","flutter","auth","verify-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"otp\": \"123456\",\n  \"type\": \"EMAIL_VERIFY\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Verify email OTP after registration.\n\ntype options: EMAIL_VERIFY | PASSWORD_RESET | LOGIN_OTP\n\nResponse: { success, message, token, user }\n\n⚠️ Save the token from response!"
          }
        },
        {
          "name": "3. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  console.log('Token saved!');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/flutter/auth/login", "host": ["{{baseUrl}}"], "path": ["api","flutter","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"test1234\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Login with email & password.\n\nResponse: { success, token, user }\n\nError codes:\n- EMAIL_NOT_VERIFIED → go to verify-otp\n- PENDING_APPROVAL → wait for admin\n\n✅ Token auto-saved to collection variable"
          }
        },
        {
          "name": "4. Resend OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/flutter/auth/resend-otp", "host": ["{{baseUrl}}"], "path": ["api","flutter","auth","resend-otp"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"type\": \"EMAIL_VERIFY\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Resend OTP to email.\n\ntype: EMAIL_VERIFY | PASSWORD_RESET | LOGIN_OTP"
          }
        },
        {
          "name": "5. Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/flutter/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["api","flutter","auth","forgot-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Send password reset OTP to email."
          }
        },
        {
          "name": "6. Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/flutter/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["api","flutter","auth","reset-password"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"otp\": \"123456\",\n  \"password\": \"newpassword123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Reset password using OTP from forgot-password.\n\nRequired: email, otp, password (min 8 chars)"
          }
        }
      ]
    },
    {
      "name": "👤 Profile",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/flutter/profile/me", "host": ["{{baseUrl}}"], "path": ["api","flutter","profile","me"] },
            "description": "Get current logged-in user's full profile.\n\nReturns: id, name, email, phone, profile (all fields), photos[]"
          }
        },
        {
          "name": "Get User Profile by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/flutter/profile/:id", "host": ["{{baseUrl}}"], "path": ["api","flutter","profile",":id"], "variable": [{ "key": "id", "value": "USER_ID_HERE" }] },
            "description": "Get any user's profile by their ID.\n\nNote: phone/email hidden for non-premium viewers"
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/onboarding", "host": ["{{baseUrl}}"], "path": ["api","onboarding"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"name\": \"Updated Name\",\n  \"phone\": \"+919876543210\",\n  \"gender\": \"MALE\",\n  \"dob\": \"1995-06-15\",\n  \"height\": 175,\n  \"weight\": 70,\n  \"religion\": \"Hindu\",\n  \"caste\": \"Brahmin\",\n  \"subCaste\": \"Sharma\",\n  \"gotra\": \"Bharadwaj\",\n  \"motherTongue\": \"Hindi\",\n  \"education\": \"B.Tech\",\n  \"profession\": \"Software Engineer\",\n  \"income\": \"10-15 LPA\",\n  \"country\": \"India\",\n  \"state\": \"Maharashtra\",\n  \"city\": \"Mumbai\",\n  \"aboutMe\": \"I am a software engineer looking for a life partner.\",\n  \"maritalStatus\": \"NEVER_MARRIED\",\n  \"complexion\": \"Fair\",\n  \"bodyType\": \"Athletic\",\n  \"diet\": \"Vegetarian\",\n  \"smoking\": \"NO\",\n  \"drinking\": \"NO\",\n  \"familyType\": \"Nuclear\",\n  \"familyStatus\": \"Middle Class\",\n  \"partnerAgeMin\": 22,\n  \"partnerAgeMax\": 28,\n  \"partnerHeightMin\": 155,\n  \"partnerHeightMax\": 170,\n  \"partnerReligion\": \"Hindu\",\n  \"partnerEducation\": \"Graduate\",\n  \"partnerProfession\": \"Any\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Update user profile. Send only fields you want to update.\n\nRequired: email (to identify user)\nAll other fields optional."
          }
        }
      ]
    },
    {
      "name": "💑 Matches",
      "item": [
        {
          "name": "Get Matches (Browse)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/matches?page=1&limit=12",
              "host": ["{{baseUrl}}"],
              "path": ["api","matches"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "12" },
                { "key": "ageMin", "value": "22", "disabled": true },
                { "key": "ageMax", "value": "30", "disabled": true },
                { "key": "religion", "value": "Hindu", "disabled": true },
                { "key": "country", "value": "India", "disabled": true },
                { "key": "state", "value": "Maharashtra", "disabled": true },
                { "key": "city", "value": "Mumbai", "disabled": true },
                { "key": "education", "value": "B.Tech", "disabled": true },
                { "key": "profession", "value": "Software Engineer", "disabled": true },
                { "key": "heightMin", "value": "155", "disabled": true },
                { "key": "heightMax", "value": "175", "disabled": true },
                { "key": "maritalStatus", "value": "NEVER_MARRIED", "disabled": true }
              ]
            },
            "description": "Browse match profiles. Auto-filters opposite gender.\n\nFree users: max 5 profiles\nPremium users: unlimited with pagination\n\nOptional filters (enable in Postman):\n- ageMin, ageMax\n- religion\n- country, state, city\n- education, profession\n- heightMin, heightMax\n- maritalStatus"
          }
        },
        {
          "name": "Search Profiles",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/search?q=engineer&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api","search"],
              "query": [
                { "key": "q", "value": "engineer" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "Search profiles by name, city, profession etc."
          }
        }
      ]
    },
    {
      "name": "💌 Interests",
      "item": [
        {
          "name": "Send Interest",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/interest", "host": ["{{baseUrl}}"], "path": ["api","interest"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiverId\": \"TARGET_USER_ID\",\n  \"message\": \"Hi, I liked your profile!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Send interest to another user.\n\nRequired: receiverId\nOptional: message"
          }
        },
        {
          "name": "Get Received Interests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/interest?type=received&limit=20&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["api","interest"],
              "query": [
                { "key": "type", "value": "received" },
                { "key": "limit", "value": "20" },
                { "key": "offset", "value": "0" }
              ]
            },
            "description": "Get interests received from other users."
          }
        },
        {
          "name": "Get Sent Interests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/interest?type=sent&limit=20&offset=0",
              "host": ["{{baseUrl}}"],
              "path": ["api","interest"],
              "query": [
                { "key": "type", "value": "sent" },
                { "key": "limit", "value": "20" },
                { "key": "offset", "value": "0" }
              ]
            },
            "description": "Get interests you have sent."
          }
        },
        {
          "name": "Accept / Reject Interest",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/interest/:id", "host": ["{{baseUrl}}"], "path": ["api","interest",":id"], "variable": [{ "key": "id", "value": "INTEREST_ID" }] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACCEPTED\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Accept or reject an interest.\n\nstatus: ACCEPTED | REJECTED"
          }
        }
      ]
    },
    {
      "name": "💬 Chat",
      "item": [
        {
          "name": "Get All Chat Rooms",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
